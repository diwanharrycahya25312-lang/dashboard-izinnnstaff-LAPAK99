<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LAPAK99 • COMMAND CENTER</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        }

        @import url('https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap');
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&display=swap');
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');

        :root {
            --primary: #ff8c00;
            --primary-dark: #e67e00;
            --primary-light: #ffa64d;
            --primary-glow: rgba(255, 140, 0, 0.5);
            --danger: #ff4757;
            --danger-glow: rgba(255, 71, 87, 0.5);
            --success: #00d68f;
            --success-glow: rgba(0, 214, 143, 0.5);
            --warning: #ffaa00;
            --warning-glow: rgba(255, 170, 0, 0.5);
            --dark-bg: #0a0a0f;
            --dark-card: rgba(18, 18, 26, 0.8);
            --dark-border: rgba(255, 140, 0, 0.2);
            --text-primary: #ffffff;
            --text-secondary: #a0a0b0;
            --text-muted: #6a6a7a;
            --glass-bg: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 140, 0, 0.15);
        }

        body {
            background: var(--dark-bg);
            min-height: 100vh;
            padding: 24px;
            position: relative;
            font-family: 'Inter', sans-serif;
        }

        /* Animated Background */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: 
                radial-gradient(circle at 20% 30%, rgba(255, 140, 0, 0.08) 0%, transparent 40%),
                radial-gradient(circle at 80% 70%, rgba(255, 140, 0, 0.06) 0%, transparent 40%),
                radial-gradient(circle at 40% 80%, rgba(255, 215, 0, 0.05) 0%, transparent 50%),
                radial-gradient(circle at 60% 20%, rgba(255, 140, 0, 0.04) 0%, transparent 50%);
            pointer-events: none;
            z-index: 0;
        }

        /* Grid Pattern Overlay */
        body::after {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                linear-gradient(rgba(255, 140, 0, 0.02) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255, 140, 0, 0.02) 1px, transparent 1px);
            background-size: 50px 50px;
            pointer-events: none;
            z-index: 0;
        }

        .dashboard {
            max-width: 1600px;
            margin: 0 auto;
            position: relative;
            z-index: 10;
        }

        /* Premium Header */
        .header {
            background: rgba(12, 12, 20, 0.8);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 32px;
            padding: 20px 32px;
            margin-bottom: 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.7);
            position: relative;
            overflow: hidden;
        }

        .header::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--primary), var(--primary), transparent);
            animation: scan 3s linear infinite;
        }

        @keyframes scan {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }

        .brand {
            position: relative;
        }

        .brand h1 {
            font-size: 32px;
            font-weight: 800;
            background: linear-gradient(135deg, #fff 0%, var(--primary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 6px;
            letter-spacing: -0.5px;
            text-shadow: 0 0 30px rgba(255, 140, 0, 0.3);
        }

        .brand p {
            color: var(--text-secondary);
            font-size: 14px;
            font-weight: 500;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        /* Premium DateTime Cards */
        .datetime-wrapper {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .date-card {
            background: linear-gradient(135deg, rgba(20, 20, 30, 0.9), rgba(10, 10, 20, 0.95));
            border: 1px solid rgba(255, 215, 0, 0.3);
            border-radius: 24px;
            padding: 12px 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            box-shadow: 0 15px 35px -10px rgba(255, 215, 0, 0.3);
        }

        .date-card::before {
            content: '';
            position: absolute;
            inset: -50%;
            background: radial-gradient(circle, rgba(255, 215, 0, 0.15) 0%, transparent 70%);
            animation: rotate 15s linear infinite;
        }

        .date-content {
            position: relative;
            z-index: 2;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .date-day {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 38px;
            font-weight: 800;
            color: #ffd700;
            line-height: 1;
            text-shadow: 0 0 30px rgba(255, 215, 0, 0.5);
        }

        .date-month-year {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.6);
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-top: 4px;
        }

        .time-card {
            background: linear-gradient(135deg, rgba(20, 20, 30, 0.9), rgba(10, 10, 20, 0.95));
            border: 1px solid rgba(255, 215, 0, 0.3);
            border-radius: 24px;
            padding: 12px 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            box-shadow: 0 15px 35px -10px rgba(255, 215, 0, 0.3);
            min-width: 200px;
        }

        .time-card::before {
            content: '';
            position: absolute;
            inset: -50%;
            background: radial-gradient(circle, rgba(255, 215, 0, 0.15) 0%, transparent 70%);
            animation: rotate 15s linear infinite reverse;
        }

        .time-content {
            position: relative;
            z-index: 2;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .time-digital {
            font-family: 'Orbitron', monospace;
            font-size: 32px;
            font-weight: 700;
            color: #ffd700;
            line-height: 1;
            text-shadow: 0 0 30px rgba(255, 215, 0, 0.5);
            letter-spacing: 4px;
        }

        .time-period {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.4);
            text-transform: uppercase;
            letter-spacing: 3px;
            margin-top: 4px;
        }

        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        /* Quick Panel Premium */
        .quick-panel {
            background: rgba(15, 15, 25, 0.7);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 40px;
            padding: 40px 48px;
            margin-bottom: 32px;
            box-shadow: 0 30px 50px -20px rgba(0, 0, 0, 0.8);
            position: relative;
            overflow: hidden;
        }

        .quick-panel::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, transparent, var(--primary), var(--primary-light), var(--primary), transparent);
            animation: scan 4s linear infinite;
        }

        .panel-title {
            color: var(--text-primary);
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 32px;
            display: flex;
            align-items: center;
            gap: 16px;
            position: relative;
            z-index: 2;
        }

        .panel-title-glow {
            width: 16px;
            height: 16px;
            background: var(--primary);
            border-radius: 6px;
            transform: rotate(45deg);
            box-shadow: 0 0 30px var(--primary);
            animation: glowPulse 2s infinite;
        }

        @keyframes glowPulse {
            0%, 100% { opacity: 0.8; transform: rotate(45deg) scale(1); }
            50% { opacity: 1; transform: rotate(45deg) scale(1.2); box-shadow: 0 0 50px var(--primary); }
        }

        .quick-form {
            display: grid;
            grid-template-columns: 2fr 2fr 1.5fr 1.5fr;
            gap: 24px;
            position: relative;
            z-index: 2;
        }

        /* Premium Select Fields */
        .select-wrapper {
            position: relative;
        }

        .select-field {
            width: 100%;
            background: rgba(20, 20, 30, 0.8);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 2px solid rgba(255, 140, 0, 0.2);
            border-radius: 28px;
            padding: 22px 28px;
            color: var(--text-primary);
            font-size: 16px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            appearance: none;
            -webkit-appearance: none;
            background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23ff8c00' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
            background-repeat: no-repeat;
            background-position: right 24px center;
            background-size: 20px;
        }

        .select-field:hover {
            border-color: var(--primary);
            background: rgba(30, 30, 40, 0.9);
            box-shadow: 0 0 0 4px rgba(255, 140, 0, 0.1);
        }

        .select-field:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(255, 140, 0, 0.2);
        }

        .select-field option {
            background: #1a1a24;
            color: var(--text-primary);
            padding: 16px;
            font-size: 15px;
        }

        /* Premium Buttons */
        .btn-quick {
            border: none;
            border-radius: 28px;
            padding: 22px 32px;
            font-weight: 700;
            font-size: 18px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 14px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
            letter-spacing: 0.5px;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }

        .btn-quick::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.2);
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }

        .btn-quick:hover::before {
            width: 300px;
            height: 300px;
        }

        .btn-quick:hover {
            transform: translateY(-4px);
        }

        .btn-quick:disabled {
            opacity: 0.4;
            cursor: not-allowed;
            transform: none;
            pointer-events: none;
        }

        .btn-quick:disabled::before {
            display: none;
        }

        .btn-keluar {
            background: linear-gradient(135deg, rgba(42, 26, 10, 0.9), rgba(58, 37, 16, 0.9));
            border: 2px solid var(--primary);
            color: var(--primary);
            box-shadow: 0 15px 30px -10px rgba(255, 140, 0, 0.5);
        }

        .btn-keluar:hover:not(:disabled) {
            background: linear-gradient(135deg, rgba(58, 37, 16, 0.9), rgba(74, 48, 22, 0.9));
            box-shadow: 0 25px 40px -10px var(--primary-glow);
        }

        .btn-kembali {
            background: linear-gradient(135deg, rgba(10, 42, 26, 0.9), rgba(16, 58, 32, 0.9));
            border: 2px solid var(--success);
            color: var(--success);
            box-shadow: 0 15px 30px -10px rgba(0, 214, 143, 0.5);
        }

        .btn-kembali:hover:not(:disabled) {
            background: linear-gradient(135deg, rgba(16, 58, 32, 0.9), rgba(22, 74, 38, 0.9));
            box-shadow: 0 25px 40px -10px var(--success-glow);
        }

        .status-message {
            margin-top: 20px;
            padding: 16px 24px;
            background: rgba(255, 140, 0, 0.1);
            border: 1px solid rgba(255, 140, 0, 0.2);
            border-radius: 40px;
            color: var(--text-primary);
            font-size: 15px;
            font-weight: 500;
            text-align: center;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            transition: all 0.3s ease;
        }

        /* Stats Cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
            margin-bottom: 32px;
        }

        .stat-card {
            background: rgba(18, 18, 26, 0.7);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 32px;
            padding: 32px;
            display: flex;
            align-items: center;
            gap: 24px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(circle at var(--x, 50%) var(--y, 50%), rgba(255, 140, 0, 0.2), transparent 70%);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .stat-card:hover {
            border-color: var(--primary);
            transform: translateY(-4px) scale(1.02);
            box-shadow: 0 20px 40px -15px rgba(255, 140, 0, 0.4);
        }

        .stat-card:hover::before {
            opacity: 1;
        }

        .stat-icon {
            width: 80px;
            height: 80px;
            background: rgba(30, 30, 42, 0.8);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 2px solid rgba(255, 140, 0, 0.3);
            border-radius: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 38px;
            color: var(--primary);
            transition: all 0.3s;
        }

        .stat-card:hover .stat-icon {
            background: rgba(255, 140, 0, 0.15);
            border-color: var(--primary);
            transform: scale(1.1) rotate(5deg);
        }

        .stat-info h3 {
            color: var(--text-secondary);
            font-size: 16px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }

        .stat-info .value {
            color: var(--text-primary);
            font-size: 56px;
            font-weight: 800;
            line-height: 1;
            text-shadow: 0 0 30px rgba(255, 140, 0, 0.4);
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .stat-badge {
            position: absolute;
            top: 16px;
            right: 16px;
            background: rgba(255, 140, 0, 0.15);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-radius: 40px;
            padding: 6px 16px;
            font-size: 12px;
            color: var(--primary);
            border: 1px solid rgba(255, 140, 0, 0.3);
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        /* Active Section */
        .active-section {
            background: rgba(18, 18, 26, 0.7);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 40px;
            padding: 40px;
            margin-bottom: 32px;
            transition: all 0.3s ease;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
        }

        .section-header h2 {
            color: var(--text-primary);
            font-size: 28px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .live-indicator {
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(30, 30, 42, 0.8);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 140, 0, 0.3);
            border-radius: 40px;
            padding: 12px 24px;
        }

        .live-dot {
            width: 12px;
            height: 12px;
            background: var(--danger);
            border-radius: 50%;
            box-shadow: 0 0 20px var(--danger);
            animation: livePulse 1.5s infinite;
        }

        @keyframes livePulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.5; transform: scale(1.3); }
        }

        .active-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 28px;
        }

        /* Premium Timer Card */
        .timer-card {
            background: rgba(22, 22, 32, 0.8);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 140, 0, 0.2);
            border-radius: 36px;
            padding: 28px;
            display: flex;
            align-items: center;
            gap: 28px;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
            cursor: pointer;
        }

        .timer-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--primary), transparent);
            transform: translateX(-100%);
            transition: transform 0.6s;
        }

        .timer-card:hover::before {
            transform: translateX(100%);
        }

        .timer-card:hover {
            border-color: var(--primary);
            transform: translateY(-6px) scale(1.02);
            box-shadow: 0 30px 50px -20px rgba(255, 140, 0, 0.5);
        }

        /* Late Card Premium Style */
        .timer-card.late-card {
            border: 2px solid var(--danger);
            background: linear-gradient(145deg, rgba(40, 20, 20, 0.95), rgba(60, 20, 20, 0.9));
            box-shadow: 0 0 40px var(--danger-glow), inset 0 0 40px rgba(255, 71, 87, 0.1);
            animation: lateGlow 2s ease-in-out infinite;
        }

        .timer-card.late-card::after {
            content: '⚠️ TERLAMBAT';
            position: absolute;
            top: 16px;
            right: 20px;
            background: linear-gradient(135deg, var(--danger), #ff6b81);
            color: white;
            font-size: 12px;
            font-weight: 800;
            padding: 6px 16px;
            border-radius: 40px;
            letter-spacing: 1px;
            box-shadow: 0 0 30px var(--danger);
            animation: lateTextPulse 1.5s infinite;
            z-index: 10;
        }

        @keyframes lateGlow {
            0%, 100% { 
                box-shadow: 0 0 40px var(--danger-glow), inset 0 0 40px rgba(255, 71, 87, 0.1);
                border-color: var(--danger);
            }
            50% { 
                box-shadow: 0 0 70px var(--danger-glow), inset 0 0 70px rgba(255, 71, 87, 0.2);
                border-color: #ff6b81;
            }
        }

        @keyframes lateTextPulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.1); opacity: 0.9; background: linear-gradient(135deg, #ff6b81, var(--danger)); }
        }

        /* Circular Progress */
        .circular-progress {
            position: relative;
            width: 120px;
            height: 120px;
            flex-shrink: 0;
        }

        .circular-progress svg {
            width: 120px;
            height: 120px;
            transform: rotate(-90deg);
        }

        .progress-bg {
            fill: none;
            stroke: rgba(255, 255, 255, 0.05);
            stroke-width: 8;
        }

        .progress-fill {
            fill: none;
            stroke: var(--primary);
            stroke-width: 8;
            stroke-linecap: round;
            stroke-dasharray: 283;
            stroke-dashoffset: 0;
            transition: stroke-dashoffset 0.3s linear;
            filter: drop-shadow(0 0 12px var(--primary-glow));
        }

        .progress-fill.late-fill {
            stroke: var(--danger);
            filter: drop-shadow(0 0 20px var(--danger-glow));
            animation: progressLateGlow 1.5s infinite;
        }

        @keyframes progressLateGlow {
            0%, 100% { filter: drop-shadow(0 0 20px var(--danger-glow)); }
            50% { filter: drop-shadow(0 0 40px var(--danger-glow)); }
        }

        .timer-value {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: var(--text-primary);
            font-weight: 700;
            font-size: 28px;
            text-align: center;
            line-height: 1.2;
            text-shadow: 0 0 20px rgba(255, 140, 0, 0.5);
            font-family: 'Orbitron', monospace;
        }

        .timer-value.late-value {
            color: var(--danger);
            text-shadow: 0 0 30px var(--danger-glow);
            animation: valueLatePulse 1.5s infinite;
            font-size: 24px;
        }

        @keyframes valueLatePulse {
            0%, 100% { transform: translate(-50%, -50%) scale(1); }
            50% { transform: translate(-50%, -50%) scale(1.15); }
        }

        .timer-value small {
            display: block;
            font-size: 11px;
            color: var(--text-secondary);
            font-weight: 400;
            margin-top: 4px;
            font-family: 'Inter', sans-serif;
        }

        .timer-value.late-value small {
            color: rgba(255, 200, 200, 0.8);
        }

        .timer-info {
            flex: 1;
            position: relative;
            z-index: 2;
        }

        .timer-info h3 {
            color: var(--text-primary);
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 8px;
            letter-spacing: -0.3px;
        }

        .timer-info .job {
            color: var(--primary);
            font-size: 15px;
            font-weight: 600;
            margin-bottom: 12px;
            display: inline-block;
            padding: 6px 18px;
            background: rgba(255, 140, 0, 0.12);
            border-radius: 40px;
            border: 1px solid rgba(255, 140, 0, 0.3);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }

        .timer-info .job.late-job {
            background: rgba(255, 71, 87, 0.15);
            border-color: rgba(255, 71, 87, 0.4);
            color: #ff8a93;
        }

        .timer-meta {
            display: flex;
            gap: 20px;
            color: var(--text-secondary);
            font-size: 14px;
        }

        .timer-meta.late-meta {
            color: rgba(255, 200, 200, 0.9);
        }

        .timer-meta span {
