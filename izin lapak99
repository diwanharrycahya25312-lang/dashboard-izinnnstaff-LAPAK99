    <script>
        // =============================================
        // GOOGLE SHEETS INTEGRATION (TIDAK DIUBAH)
        // =============================================
        
        const WEB_APP_URL = "https://script.google.com/macros/s/AKfycbzjdAOQmqv8jmpKfvue0avY0cc89uTmY4G8VjNcvt-5dZWqGsV8viZXsITDhq5nvymn/exec";
        
        // Data staff yang sedang izin (untuk timer)
        let activeStaff = [];
        let lateStaff = [];
        
        // Variabel untuk menyimpan pilihan terakhir
        let lastSelectedNama = "";
        let lastSelectedJobdesk = "";

        // =============================================
        // FUNGSI CEK STATUS STAFF (CEGAH DOUBLE)
        // =============================================
        
        function checkStaffStatus() {
            const namaSelect = document.getElementById('selectNama');
            const btnKeluar = document.getElementById('btnKeluar');
            const btnKembali = document.getElementById('btnKembali');
            const statusMessage = document.getElementById('statusMessage');
            
            const selectedNama = namaSelect ? namaSelect.value : "";
            
            if (!selectedNama) {
                btnKeluar.disabled = false;
                btnKembali.disabled = false;
                statusMessage.innerHTML = "⚡ PILIH NAMA + JOBDESK";
                statusMessage.style.background = "rgba(255, 140, 0, 0.1)";
                return;
            }
            
            const isActive = activeStaff.some(staff => staff.nama === selectedNama);
            
            if (isActive) {
                btnKeluar.disabled = true;
                btnKembali.disabled = false;
                statusMessage.innerHTML = `⚠️ ${selectedNama} SEDANG IZIN • SILAKAN KLIK KEMBALI`;
                statusMessage.style.background = "rgba(0, 214, 143, 0.15)";
                statusMessage.style.borderColor = "rgba(0, 214, 143, 0.3)";
            } else {
                btnKeluar.disabled = false;
                btnKembali.disabled = true;
                statusMessage.innerHTML = `✅ ${selectedNama} TERSEDIA • SILAKAN IZIN KELUAR`;
                statusMessage.style.background = "rgba(255, 140, 0, 0.1)";
                statusMessage.style.borderColor = "rgba(255, 140, 0, 0.2)";
            }
        }

        // =============================================
        // FUNGSI UNTUK MODAL
        // =============================================
        
        function showKeluarModal() {
            const modal = document.getElementById('keluarModal');
            const modalList = document.getElementById('keluarModalList');
            
            if (activeStaff.length === 0) {
                modalList.innerHTML = '<div class="modal-empty">✨ TIDAK ADA STAFF SEDANG IZIN</div>';
            } else {
                let html = '';
                activeStaff.forEach(staff => {
                    const waktuKeluar = new Date(staff.waktuKeluar);
                    const waktuStr = waktuKeluar.toLocaleTimeString('id-ID', {
                        hour: '2-digit',
                        minute: '2-digit'
                    });
                    
                    const now = new Date();
                    const elapsedMinutes = Math.floor((now - waktuKeluar) / 60000);
                    const isLate = elapsedMinutes > 16;
                    
                    html += `
                        <div class="modal-item">
                            <div class="modal-item-info">
                                <h4>${staff.nama}</h4>
                                <p>${staff.jobdesk}</p>
                            </div>
                            <div class="modal-item-time">
                                <span>🕒 ${waktuStr}</span>
                                <span class="modal-item-badge ${isLate ? 'terlambat' : 'keluar'}">
                                    ${isLate ? `Terlambat ${elapsedMinutes - 16} menit` : `Izin ke-${staff.izinKe || 1}`}
                                </span>
                            </div>
                        </div>
                    `;
                });
                modalList.innerHTML = html;
            }
            
            modal.classList.add('active');
        }

        function closeKeluarModal() {
            document.getElementById('keluarModal').classList.remove('active');
        }

        function showTerlambatModal() {
            const modal = document.getElementById('terlambatModal');
            const modalList = document.getElementById('terlambatModalList');
            
            const now = new Date();
            lateStaff = activeStaff.filter(staff => {
                const keluarTime = new Date(staff.waktuKeluar);
                const elapsedMinutes = Math.floor((now - keluarTime) / 60000);
                return elapsedMinutes > 16;
            });
            
            if (lateStaff.length === 0) {
                modalList.innerHTML = '<div class="modal-empty">✅ TIDAK ADA STAFF TERLAMBAT</div>';
            } else {
                let html = '';
                lateStaff.forEach(staff => {
                    const waktuKeluar = new Date(staff.waktuKeluar);
                    const elapsedMinutes = Math.floor((now - waktuKeluar) / 60000);
                    const terlambatMenit = elapsedMinutes - 16;
                    
                    html += `
                        <div class="modal-item">
                            <div class="modal-item-info">
                                <h4>${staff.nama}</h4>
                                <p>${staff.jobdesk}</p>
                            </div>
                            <div>
                                <span class="modal-item-badge terlambat">Terlambat ${terlambatMenit} menit</span>
                            </div>
                        </div>
                    `;
                });
                modalList.innerHTML = html;
            }
            
            modal.classList.add('active');
        }

        function closeTerlambatModal() {
            document.getElementById('terlambatModal').classList.remove('active');
        }

        window.addEventListener('click', function(event) {
            const keluarModal = document.getElementById('keluarModal');
            const terlambatModal = document.getElementById('terlambatModal');
            
            if (event.target === keluarModal) {
                keluarModal.classList.remove('active');
            }
            if (event.target === terlambatModal) {
                terlambatModal.classList.remove('active');
            }
        });

        // =============================================
        // FUNGSI UNTUK PREMIUM DATE & TIME
        // =============================================
        
        function updatePremiumDateTime() {
            const now = new Date();
            
            const day = now.getDate();
            const month = now.toLocaleDateString('id-ID', { month: 'long' }).toUpperCase();
            const year = now.getFullYear();
            
            document.getElementById('currentDay').textContent = day;
            document.getElementById('currentMonthYear').textContent = `${month} ${year}`;
            
            const hours = now.getHours();
            const minutes = now.getMinutes();
            const seconds = now.getSeconds();
            
            const timeString = `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
            document.getElementById('currentTime').textContent = timeString;
            document.getElementById('currentPeriod').textContent = 'WIB';
        }

        setInterval(updatePremiumDateTime, 1000);

        // =============================================
        // FUNGSI UNTUK RESET HISTORY OTOMATIS (48 JAM)
        // =============================================
        
        function checkHistoryReset() {
            const lastReset = localStorage.getItem('lastHistoryReset');
            const now = new Date().getTime();
            const fortyEightHours = 48 * 60 * 60 * 1000;
            
            if (lastReset) {
                const timeSinceReset = now - parseInt(lastReset);
                
                if (timeSinceReset >= fortyEightHours) {
                    historyLog = [];
                    localStorage.setItem('lapak99_history', JSON.stringify(historyLog));
                    localStorage.setItem('lastHistoryReset', now.toString());
                    updateHistory();
                }
            } else {
                localStorage.setItem('lastHistoryReset', now.toString());
            }
        }

        setInterval(checkHistoryReset, 60000);

        // =============================================
        // FUNGSI UNTUK TOGGLE HISTORY
        // =============================================
        
        function toggleHistory() {
            const section = document.getElementById('historySection');
            const icon = document.getElementById('toggleIcon');
            const text = document.getElementById('toggleText');
            
            section.classList.toggle('collapsed');
            
            if (section.classList.contains('collapsed')) {
                icon.innerHTML = '▶';
                text.innerHTML = 'Tampilkan';
            } else {
                icon.innerHTML = '▼';
                text.innerHTML = 'Sembunyikan';
            }
        }

        // =============================================
        // FUNGSI UTAMA KIRIM DATA (TIDAK DIUBAH)
        // =============================================
        
        function kirimDataKeSheet(statusIzin) {
            const namaSelect = document.querySelector('select[name="nama"]');
            const jobdeskSelect = document.querySelector('select[name="jobdesk"]');
            
            const nama = namaSelect ? namaSelect.value : "";
            const jobdesk = jobdeskSelect ? jobdeskSelect.value : "";
            
            if (!nama || !jobdesk || nama === "" || jobdesk === "") {
                alert('⚠️ PILIH NAMA DAN JOBDESK TERLEBIH DAHULU!');
                return;
            }

            if (statusIzin === 'Keluar') {
                const isAlreadyActive = activeStaff.some(staff => staff.nama === nama);
                if (isAlreadyActive) {
                    alert(`⚠️ ${nama} SEDANG IZIN KELUAR! TIDAK BISA IZIN GANDA.`);
                    return;
                }
            }

            if (statusIzin === 'Kembali') {
                const isActive = activeStaff.some(staff => staff.nama === nama);
                if (!isActive) {
                    alert(`⚠️ ${nama} TIDAK SEDANG IZIN KELUAR!`);
                    return;
                }
            }
            
            const payload = {
                nama: nama,
                jobdesk: jobdesk,
                status: statusIzin
            };

            const toast = document.createElement('div');
            toast.className = 'toast';
            toast.innerHTML = `<span>⏳</span><span>MENGIRIM DATA...</span>`;
            document.getElementById('toastContainer').appendChild(toast);

            fetch(WEB_APP_URL, {
                method: "POST",
                mode: "no-cors",
                headers: {
                    "Content-Type": "text/plain"
                },
                body: JSON.stringify(payload)
            })
            .then(() => {
                toast.remove();
                
                if (statusIzin === 'Keluar') {
                    const waktuKeluar = new Date();
                    const izinKe = activeStaff.filter(s => s.nama === nama).length + 1;
                    
                    activeStaff.push({
                        nama: nama,
                        jobdesk: jobdesk,
                        waktuKeluar: waktuKeluar,
                        izinKe: izinKe
                    });
                    
                    showToast(`✅ ${nama} IZIN KELUAR`, 'success');
                    addToHistory('Keluar', nama, jobdesk);
                    
                } else if (statusIzin === 'Kembali') {
                    const staffKeluar = activeStaff.find(s => s.nama === nama);
                    if (staffKeluar) {
                        const waktuKeluar = new Date(staffKeluar.waktuKeluar);
                        const waktuKembali = new Date();
                        const durasiMenit = Math.floor((waktuKembali - waktuKeluar) / 60000);
                        const durasiDetik = Math.floor(((waktuKembali - waktuKeluar) % 60000) / 1000);
                        
                        const durasiText = `${durasiMenit} menit ${durasiDetik} detik`;
                        const isLate = durasiMenit > 16;
                        
                        showToast(`✅ ${nama} KEMBALI • Durasi: ${durasiText}`, 'success');
                        addToHistory(isLate ? 'Terlambat' : 'Kembali', nama, jobdesk, durasiText);
                    }
                    
                    activeStaff = activeStaff.filter(s => s.nama !== nama);
                }
                
                updateActiveStaffTimers();
                checkStaffStatus();
                
                lastSelectedNama = nama;
                lastSelectedJobdesk = jobdesk;
            })
            .catch(err => {
                console.error("❌ Gagal:", err);
                toast.remove();
                showToast(`❌ Gagal mengirim data: ${err.message}`, 'error');
            });
        }

        // =============================================
        // FUNGSI UPDATE TIMER
        // =============================================
        
        function updateActiveStaffTimers() {
            const activeGrid = document.getElementById('activeStaffGrid');
            if (!activeGrid) return;
            
            if (activeStaff.length === 0) {
                activeGrid.innerHTML = '<div style="color:#6a6a7a; text-align:center; padding:80px; background:rgba(255,255,255,0.02); border-radius:36px; backdrop-filter:blur(10px); grid-column:span 2; font-size:20px; font-weight:500;">⚡ TIDAK ADA STAFF SEDANG IZIN ⚡</div>';
                return;
            }

            let html = '';
            const now = new Date();
            let totalTerlambat = 0;
            
            activeStaff.forEach((staff) => {
                const waktuKeluar = new Date(staff.waktuKeluar);
                const elapsedSeconds = Math.floor((now - waktuKeluar) / 1000);
                const totalSeconds = 16 * 60;
                const remainingSeconds = Math.max(0, totalSeconds - elapsedSeconds);
                
                const minutes = Math.floor(remainingSeconds / 60);
                const seconds = remainingSeconds % 60;
                const progress = Math.min(283, (elapsedSeconds / totalSeconds) * 283);
                const isLate = elapsedSeconds > totalSeconds;
                
                if (isLate) totalTerlambat++;
                
                const waktuKeluarStr = waktuKeluar.toLocaleTimeString('id-ID', {
                    hour: '2-digit',
                    minute: '2-digit'
                });

                const elapsedMinutes = Math.floor(elapsedSeconds / 60);
                const terlambatMenit = elapsedMinutes - 16;

                const cardClass = isLate ? 'timer-card late-card' : 'timer-card';
                const progressClass = isLate ? 'progress-fill late-fill' : 'progress-fill';
                const valueClass = isLate ? 'timer-value late-value' : 'timer-value';
                const jobClass = isLate ? 'job late-job' : 'job';
                const metaClass = isLate ? 'timer-meta late-meta' : 'timer-meta';

                let timerDisplay = '';
                if (isLate) {
                    timerDisplay = `+${terlambatMenit}'`;
                } else {
                    timerDisplay = `${minutes}:${seconds.toString().padStart(2, '0')}`;
                }

                html += `
                    <div class="${cardClass}" onclick="showStaffDetail('${staff.nama}')">
                        <div class="circular-progress">
                            <svg viewBox="0 0 100 100">
                                <circle class="progress-bg" cx="50" cy="50" r="45"></circle>
                                <circle class="${progressClass}" 
                                        cx="50" cy="50" r="45"
                                        style="stroke-dashoffset: ${progress}; stroke-dasharray: 283;"></circle>
                            </svg>
                            <div class="${valueClass}">
                                ${timerDisplay}
                                <small>${isLate ? 'terlambat' : 'tersisa'}</small>
                            </div>
                        </div>
                        <div class="timer-info">
                            <h3>${staff.nama}</h3>
                            <span class="${jobClass}">${staff.jobdesk}</span>
                            <div class="${metaClass}">
                                <span>⏱️ Izin ke-${staff.izinKe || 1}</span>
                                <span>🕒 ${waktuKeluarStr}</span>
                                ${isLate ? `<span>⚠️ +${terlambatMenit} menit</span>` : ''}
                            </div>
                        </div>
                    </div>
                `;
            });

            activeGrid.innerHTML = html;
            
            document.getElementById('sedangIzin').textContent = activeStaff.length;
            document.getElementById('totalTerlambat').textContent = totalTerlambat;
            
            document.getElementById('keluarBadge').textContent = 
                activeStaff.length > 0 ? `${activeStaff.length} staff` : 'Klik untuk lihat';
            document.getElementById('terlambatBadge').textContent = 
                totalTerlambat > 0 ? `${totalTerlambat} staff` : 'Klik untuk lihat';
        }

        function showStaffDetail(nama) {
            showToast(`📋 Detail staff: ${nama}`, 'info');
        }

        setInterval(updateActiveStaffTimers, 1000);

        // =============================================
        // FUNGSI TOAST
        // =============================================
        
        function showToast(message, type = 'success') {
            const container = document.getElementById('toastContainer');
            if (!container) return;
            
            const toast = document.createElement('div');
            toast.className = 'toast';
            toast.innerHTML = `
                <span>${type === 'success' ? '✅' : type === 'info' ? 'ℹ️' : '❌'}</span>
                <span>${message}</span>
            `;
            container.appendChild(toast);
            
            setTimeout(() => toast.remove(), 3000);
        }

        // =============================================
        // DATA STAFF (TIDAK DIUBAH)
        // =============================================
        
        const namaStaff = [
            "ESAFAT ALAN TELAUMBANU", "ROY ANDREW NADEAK", "EDWIN PRANATA",
            "FALLEN HARDINANSAH TAJU", "VERI SUSANTO", "DIWAN HARRY CAHYA",
            "KRISHNA", "SAFNALI MUSTAQIM CHANIAGO", "BILLY GUNAWAN",
            "FIRMAN ARDYANSYAH", "AGUS TEDDY WISONO", "AHMAD HABIBI KHANI",
            "RIKI ANDIKA NAINGGOLAN", "HARIANTO", "MILLIARTO VIKTOR",
            "RAM KIRAN", "DANDY MUANMAR", "RUDI IRAWAN",
            "GILANG PRAMANA", "ZULKIFLI EVANDA NASUTION", "FAISAL IDUL ANWAR TELAUMBANUA",
            "LAELA ANASILDA", "ANDI", "DESSYA SHAFIRA AL HAFNI",
            "YUSUF", "SURIYA PRAKAS", "GILBERT",
            "YODY SEBASTIAN", "MUHAMMAD RAFI LUBIS", "RIDHO SETIAWAN",
            "RAMADHAN AULANA FEBRIANTO", "MUHAMMAD RIKO", "RAIHAN SAPUTRA",
            "MUHAMMAD HAIKAL AULIA"
        ];

        const jobdeskList = [
            "CS LINE UTAMA", "CS LINE BACKUP", "CS LIVECHAT", "KAPTEN",
            "DEPO BCA", "DEPO BRI", "DEPO BNI", "DEPO EWALLET",
            "WITHDRAW", "DEPO MANUAL", "SCATTER VS EVERYBODY"
        ];

        let staffData = [];
        for (let i = 0; i < namaStaff.length; i++) {
            const jobIndex = i % jobdeskList.length;
            staffData.push({
                no: i + 1,
                nama: namaStaff[i],
                jobdesk: jobdeskList[jobIndex],
                izinKe: 0,
                durasi: 0,
                status: "",
                waktuKeluar: null,
                waktuKembali: null
            });
        }

        let historyLog = [];
        let currentFilter = 'all';

        function loadLocalHistory() {
            const saved = localStorage.getItem('lapak99_history');
            if (saved) {
                try {
                    historyLog = JSON.parse(saved);
                    updateHistory();
                } catch (e) {
                    console.log('Error loading history');
                }
            }
        }

        function saveLocalHistory() {
            localStorage.setItem('lapak99_history', JSON.stringify(historyLog));
        }

        function restoreLastSelection() {
            const selectNama = document.querySelector('select[name="nama"]');
            const selectJobdesk = document.querySelector('select[name="jobdesk"]');
            
            const savedNama = localStorage.getItem('lastSelectedNama');
            const savedJobdesk = localStorage.getItem('lastSelectedJobdesk');
            
            if (savedNama && selectNama) {
                const optionExists = Array.from(selectNama.options).some(opt => opt.value === savedNama);
                if (optionExists) {
                    selectNama.value = savedNama;
                    lastSelectedNama = savedNama;
                }
            }
            
            if (savedJobdesk && selectJobdesk) {
                const optionExists = Array.from(selectJobdesk.options).some(opt => opt.value === savedJobdesk);
                if (optionExists) {
                    selectJobdesk.value = savedJobdesk;
                    lastSelectedJobdesk = savedJobdesk;
                }
            }
        }

        function initSelects() {
            const selectNama = document.querySelector('select[name="nama"]');
            if (!selectNama) return;
            
            selectNama.innerHTML = '<option value="">🔍 PILIH NAMA STAFF</option>';
            
            staffData.forEach(staff => {
                const option = document.createElement('option');
                option.value = staff.nama;
                option.textContent = staff.nama;
                selectNama.appendChild(option);
            });
            
            restoreLastSelection();
            checkStaffStatus();
        }

        function saveSelectionToStorage() {
            const selectNama = document.querySelector('select[name="nama"]');
            const selectJobdesk = document.querySelector('select[name="jobdesk"]');
            
            if (selectNama && selectNama.value) {
                localStorage.setItem('lastSelectedNama', selectNama.value);
            }
            if (selectJobdesk && selectJobdesk.value) {
                localStorage.setItem('lastSelectedJobdesk', selectJobdesk.value);
            }
        }

        function addToHistory(action, nama, jobdesk, duration = '-') {
            const time = new Date().toLocaleTimeString('id-ID', { 
                hour: '2-digit', minute: '2-digit', second: '2-digit'
            });
            const date = new Date().toLocaleDateString('id-ID', {
                day: '2-digit', month: '2-digit'
            });

            historyLog.unshift({
                time: `${date} ${time}`,
                action: action,
                nama: nama,
                jobdesk: jobdesk,
                duration: duration
            });
            
            if (historyLog.length > 50) historyLog.pop();
            saveLocalHistory();
            updateHistory();
        }

        function updateHistory() {
            const historyBody = document.getElementById('historyBody');
            if (!historyBody) return;
            
            let filteredLog = historyLog.filter(item => currentFilter === 'all' || item.action === currentFilter);

            let html = '';
            filteredLog.forEach(item => {
                const statusClass = item.action === 'Keluar' ? 'status-keluar' : 
                                  item.action === 'Kembali' ? 'status-kembali' : 'status-terlambat';
                const durationClass = item.action === 'Terlambat' ? 'duration-late' : 'duration-normal';

                html += `
                    <tr class="history-row">
                        <td>${item.time}</td>
                        <td><span class="status-badge ${statusClass}">${item.action}</span></td>
                        <td>${item.nama}</td>
                        <td>${item.jobdesk}</td>
                        <td><span class="${durationClass}">${item.duration}</span></td>
                    </tr>
                `;
            });

            historyBody.innerHTML = html || '<tr><td colspan="5" style="text-align:center; padding:60px; color:#6a6a7a; background:rgba(255,255,255,0.02); border-radius:28px; font-size:18px;">⚡ BELUM ADA AKTIVITAS ⚡</td></tr>';
        }

        function filterHistory(filter) {
            currentFilter = filter;
            document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            updateHistory();
        }

        window.addEventListener('load', function() {
            loadLocalHistory();
            initSelects();
            updateActiveStaffTimers();
            updatePremiumDateTime();
            checkHistoryReset();
            
            const selectNama = document.querySelector('select[name="nama"]');
            const selectJobdesk = document.querySelector('select[name="jobdesk"]');
            
            if (selectNama) {
                selectNama.addEventListener('change', function() {
                    saveSelectionToStorage();
                    checkStaffStatus();
                });
            }
            if (selectJobdesk) {
                selectJobdesk.addEventListener('change', saveSelectionToStorage);
            }
        });
    </script>
</body>
</html>
